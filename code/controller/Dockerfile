#This Dockerfile was created by wwwqr-000, wwwqr, Whiteavocado-inc
#
# Some usefull commands:
# sudo docker build -t lora-controller .                            #Build the docker container
# sudo docker run -it --privileged lora-controller /start.sh        #Start the docker container
#
#
#Or, to remove the container:
# sudo docker rm $(sudo docker ps -a | grep "lora-controller" | awk '{print $1}')

#Use the latest release of ubuntu
FROM ubuntu:latest
#

#Prevent the confirmation options at install
ENV DEBIAN_FRONTEND=noninteractive
#


#Update system and setup packages and software
RUN apt-get update && apt-get install python3 python3.12-venv tmux git -y
RUN git clone https://github.com/whiteavocado-inc/long-range-htcc-ab02s.git
RUN mv long-range-htcc-ab02s/code/controller/* ./ && rm -rf long-range-htcc-ab02s
#

#Setup .env
RUN rm -rf .env_example
RUN cat << 'EOF' > .env
#Example .env generated by Dockerfile, made by wwwqr-000, wwwqr, Whiteavocado-inc

#Baud rate. (By default "921600") [str: int based]
BAUD = "921600"


#Used to encrypt and decrypt messages [str: 32 char]
#Use same keys for multiple clients for communication between them.
AES_KEY_1 = "example_encryption_key_replace!!"

#Used to set amount of AES_KEY's used. (The more, the more secure, but bigger payload size) [str: int based]
AES_KEY_COUNT = "1"

#If you enable AES or not. (Unencrypted data is send if "false" ⚠️) [str: "true" | "false"]
AES_ACTIVE = "true"

#Your nickname. Used to show others who you are. (Keep short to save payload size) [str]
NICKNAME = "anonymous"
EOF
#

#Create a venv for python
RUN python3 -m venv env
#

#Install py dependencies
RUN . env/bin/activate && python3 -m pip install pyserial pycryptodome python-dotenv
#

#Create a start script using bash
RUN cat << 'EOF' > /start.sh
#!/bin/bash

#Create serial.log if missing
touch serial.log
#

#Start tmux session
tmux new-session -d -s lora 'watch -n 1 cat serial.log'
tmux split-window -h -t lora '. env/bin/activate && python3 main.py'
tmux attach -t lora
#
EOF
#

#Give execute permissions to the start.sh file
RUN chmod +x /start.sh
#